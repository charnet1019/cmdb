# CMDB Backend Environment Configuration
# Copy this file to .env and update values for your environment

# Database (REQUIRED)
DATABASE_URL=postgresql+asyncpg://your_user:your_password@127.0.0.1:5432/cmdb

# Redis (REQUIRED)
REDIS_URL=redis://:your_redis_password@127.0.0.1:6379/0

# JWT Configuration (REQUIRED - generate a secure random key)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-random-secret-key-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24

# Encryption Key for credentials (REQUIRED)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# Application
DEBUG=false
APP_NAME=CMDB API

# CORS Origins (comma-separated or JSON array format)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000